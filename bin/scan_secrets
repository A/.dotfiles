#!/usr/bin/env python3
"""
Scan files for sensitive information using local llama.cpp server.
Usage: scan_secrets.py [directory]

Requires OLLAMA_URL env var (e.g., http://10.0.0.106:8080)
"""

import os
import sys
import requests
from pathlib import Path

BASE_URL = os.environ.get("OLLAMA_URL", "http://localhost:8080")

# File extensions to scan (text-based files)
SCAN_EXTENSIONS = {
    '.md', '.txt', '.json', '.yaml', '.yml', '.toml', '.ini', '.cfg',
    '.env', '.sh', '.bash', '.py', '.js', '.ts', '.html', '.css',
    '.xml', '.conf', '.config', '.properties', '.log'
}

# Files/dirs to skip
SKIP_PATTERNS = {'.git', '.obsidian', '__pycache__', 'node_modules', 'scan_secrets.py'}

SYSTEM_PROMPT = """You are a security auditor. Analyze the provided file content and identify ANY sensitive information including:
- AWS keys, secrets, access tokens
- API keys or tokens (any service)
- Passwords or credentials
- Private keys (SSH, PGP, etc.)
- Database connection strings with credentials
- Bearer tokens, JWT tokens
- IP addresses with credentials
- Any hardcoded secrets

Respond in this format:
- If NO sensitive info found: "CLEAN"
- If sensitive info found: List each finding with line context (don't show full secret, just first/last few chars)

Be thorough but avoid false positives on placeholder values like "YOUR_KEY_HERE" or obvious examples."""


def get_models() -> list:
    """Fetch available models from server."""
    try:
        resp = requests.get(f"{BASE_URL}/v1/models", timeout=10)
        resp.raise_for_status()
        return [m["id"] for m in resp.json().get("data", [])]
    except Exception as e:
        print(f"Error fetching models: {e}")
        return []


def select_model(models: list) -> str:
    """Select best available model (prefer larger non-finetuned)."""
    # Priority order
    preferred = [
        "gemma-3-27b",
        "gemma-3-12b-it-UD",
        "Nemotron-3-Nano-30B",
        "gpt-oss-20b",
        "gemma-3-12b",
        "gemma-3-4b",
    ]

    for pref in preferred:
        for model in models:
            if pref in model and "finetuned" not in model.lower():
                return model

    # Fallback to first available
    return models[0] if models else None


def should_scan(filepath: Path) -> bool:
    """Check if file should be scanned."""
    if any(skip in str(filepath) for skip in SKIP_PATTERNS):
        return False
    if filepath.suffix.lower() in SCAN_EXTENSIONS or filepath.suffix == '':
        return True
    return False


def scan_file(filepath: Path, model: str) -> dict:
    """Send file content to llama.cpp for analysis."""
    try:
        content = filepath.read_text(encoding='utf-8', errors='ignore')

        if not content.strip():
            return {"status": "skipped", "reason": "empty"}
        if len(content) > 50000:
            return {"status": "skipped", "reason": "too large"}

        payload = {
            "model": model,
            "messages": [
                {"role": "system", "content": SYSTEM_PROMPT},
                {"role": "user", "content": f"Analyze this file ({filepath.name}):\n\n```\n{content}\n```"}
            ],
            "temperature": 0.1,
            "max_tokens": 1024
        }

        response = requests.post(f"{BASE_URL}/v1/chat/completions", json=payload, timeout=120)
        response.raise_for_status()

        result = response.json()
        answer = result["choices"][0]["message"]["content"]

        if "CLEAN" in answer.upper() and len(answer) < 20:
            return {"status": "clean"}
        else:
            return {"status": "findings", "details": answer}

    except requests.exceptions.RequestException as e:
        return {"status": "error", "reason": str(e)}
    except Exception as e:
        return {"status": "error", "reason": str(e)}


def main():
    if not os.environ.get("OLLAMA_URL"):
        print("Warning: OLLAMA_URL not set, using localhost:8080")

    # Get target directory
    target_dir = Path(sys.argv[1]) if len(sys.argv) > 1 else Path(".")
    if not target_dir.is_dir():
        print(f"Error: {target_dir} is not a directory")
        sys.exit(1)

    # Get and select model
    print(f"Connecting to {BASE_URL}...")
    models = get_models()
    if not models:
        print("No models available. Is the server running?")
        sys.exit(1)

    model = select_model(models)
    print(f"Using model: {model}\n")

    # Collect files
    files_to_scan = []
    for filepath in target_dir.rglob("*"):
        if filepath.is_file() and should_scan(filepath):
            files_to_scan.append(filepath)

    print(f"Found {len(files_to_scan)} files to scan")
    print("=" * 60)

    findings = []

    for i, filepath in enumerate(files_to_scan, 1):
        print(f"[{i}/{len(files_to_scan)}] {filepath}")
        result = scan_file(filepath, model)

        if result["status"] == "findings":
            findings.append((filepath, result["details"]))
            print(f"  ⚠️  POTENTIAL SECRETS FOUND")
        elif result["status"] == "clean":
            print(f"  ✓ Clean")
        elif result["status"] == "skipped":
            print(f"  - Skipped: {result['reason']}")
        else:
            print(f"  ✗ Error: {result['reason']}")

    print("\n" + "=" * 60)
    print("SCAN COMPLETE")
    print("=" * 60)

    if findings:
        print(f"\n⚠️  {len(findings)} file(s) with potential sensitive info:\n")
        for filepath, details in findings:
            print(f"\n📄 {filepath}")
            print("-" * 40)
            print(details)
    else:
        print("\n✓ No sensitive information detected.")


if __name__ == "__main__":
    main()
