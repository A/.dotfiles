#!/bin/bash
set -euo pipefail

YAD="/usr/bin/yad"

current_file() {
  local file
  file=$(mpc current -f '%file%')
  if [ -z "$file" ]; then
    notify-send "Music" "Nothing playing"
    exit 1
  fi
  echo "$file"
}

current_query() {
  local file
  file=$(current_file)
  local id
  id=$(beet ls -f '$id' "path:$HOME/Music/$file" 2>/dev/null | head -1)
  if [[ -z "$id" ]]; then
    # Fallback: search by filename substring
    local basename
    basename=$(basename "$file")
    id=$(beet ls -f '$id' "path:$basename" 2>/dev/null | head -1)
  fi
  if [[ -z "$id" ]]; then
    notify-send "Music" "Track not found in beets library"
    exit 1
  fi
  echo "id:$id"
}

beet_id() {
  beet ls -f '$id' "$1" 2>/dev/null | head -1
}

beet_field() {
  local query="$1" field="$2"
  local val
  val=$(beet ls -f "\$$field" "$query" 2>/dev/null | head -1)
  [[ "$val" == "\$$field" ]] && val=""
  echo "$val"
}

sync_comments() {
  local query="$1"
  local playlists
  playlists=$(beet_field "$query" playlists)
  local comment=""
  [[ -n "$playlists" ]] && comment="playlists:$playlists"
  beet modify -y -w "$query" "comments=$comment" >/dev/null 2>&1
}

all_folders() {
  beet ls -f '$folder' 'folder::.+' 2>/dev/null | grep -v '^\$' | grep -v '^$' | sort -u
}

all_playlists() {
  beet ls -f '$playlists' 2>/dev/null | tr ',' '\n' | sed 's/^ *//;s/ *$//' | grep -v '^\$' | grep -v '^$' | sort -fu
}

# Build folder CBE value: current first, then other known folders
folder_combo() {
  local cur="$1"
  local folders
  folders=$(all_folders | grep -v "^${cur}$" || true)
  local combo="$cur"
  while IFS= read -r f; do
    [[ -n "$f" ]] && combo+="!$f"
  done <<< "$folders"
  echo "$combo"
}

# Build yad args for playlist checkboxes + new playlists field
# Sets PL_YAD_ARGS array and PL_KNOWN array
build_playlist_fields() {
  local cur_playlists="$1"
  PL_YAD_ARGS=()
  PL_KNOWN=()

  while IFS= read -r t; do
    [[ -z "$t" ]] && continue
    PL_KNOWN+=("$t")
    if [[ ",${cur_playlists,,}," == *",${t,,},"* ]]; then
      PL_YAD_ARGS+=(--field="$t:CHK" "TRUE")
    else
      PL_YAD_ARGS+=(--field="$t:CHK" "FALSE")
    fi
  done < <(all_playlists)

  PL_YAD_ARGS+=(--field="New playlists (comma-separated)" "")
}

# Parse playlist portion of yad result into comma-separated string
parse_playlist_result() {
  local new_playlists=""
  for i in "${!PL_KNOWN[@]}"; do
    local val="${1:-FALSE}"
    shift || true
    [[ "$val" == "TRUE" ]] && new_playlists+="${PL_KNOWN[$i]},"
  done
  local extra="${1:-}"
  [[ -n "$extra" ]] && new_playlists+="$extra,"
  new_playlists="${new_playlists%,}"
  echo "$new_playlists"
}

cmd_play() {
  local filter=()
  case "${1:-}" in
    inbox)      filter+=("^folder::.+"); shift ;;
    collection) filter+=("folder::.+"); shift ;;
  esac
  filter+=("$@")

  mpc clear
  beet ls -f '$path' "${filter[@]}" 2>/dev/null | while read -r path; do
    rel="${path#$HOME/Music/}"
    mpc add "$rel"
  done
  local count
  count=$(mpc playlist | wc -l)
  if [ "$count" -gt 0 ]; then
    mpc play
    notify-send "Music" "Playing $count tracks"
  else
    notify-send "Music" "No matching tracks"
  fi
}

cmd_search() {
  local selection
  selection=$(mpc search any "" | wofi --dmenu --conf ~/.config/wofi/config --prompt "Search music")
  [ -z "$selection" ] && exit 0
  mpc searchadd filename "$selection"
  mpc play $(mpc playlist | wc -l)
}

cmd_playlist() {
  local playlist
  playlist=$(mpc lsplaylists | wofi --dmenu --conf ~/.config/wofi/config --prompt "Playlist")
  [ -z "$playlist" ] && exit 0
  mpc clear
  mpc load "$playlist"
  mpc play
}

cmd_random() {
  local count
  count=$(echo -e "5\n10\n20\n50" | wofi --dmenu --conf ~/.config/wofi/config --prompt "How many random tracks?")
  [ -z "$count" ] && exit 0
  mpc clear
  beet random -n "$count" -f '$path' | while read -r path; do
    rel="${path#$HOME/Music/}"
    mpc add "$rel"
  done
  mpc play
}

cmd_update() {
  local query
  query=$(current_query)
  local track
  track=$(mpc current -f '%artist% - %title%')

  local cur_folder cur_playlists
  cur_folder=$(beet_field "$query" folder)
  cur_playlists=$(beet_field "$query" playlists)

  build_playlist_fields "$cur_playlists"

  local result
  result=$($YAD --form --title "Update: $track" \
    --separator='|' \
    --field="Folder:CBE" "$(folder_combo "$cur_folder")" \
    --field="Playlists:LBL" "" \
    "${PL_YAD_ARGS[@]}" \
    2>/dev/null) || exit 0

  IFS='|' read -ra fields <<< "$result"
  local folder="${fields[0]}"
  # fields[1] is LBL
  local playlists
  playlists=$(parse_playlist_result "${fields[@]:2}")

  local mods=()
  [ "$folder" != "$cur_folder" ] && mods+=("folder=$folder" "genre=$folder")
  [ "$playlists" != "$cur_playlists" ] && mods+=("playlists=$playlists")

  if [ ${#mods[@]} -gt 0 ]; then
    local item_id
    item_id=$(beet_id "$query")
    beet modify -y "$query" "${mods[@]}"
    local id_query="id:$item_id"
    beet move "$id_query"
    sync_comments "$id_query"
    cmd_splupdate_quiet
    local pos
    pos=$(mpc current -f '%position%')
    mpc del "$pos"
    mpc update --wait >/dev/null 2>&1 &
    notify-send "Music Update" "Updated: ${mods[*]}"
  else
    notify-send "Music Update" "No changes"
  fi
}

cmd_collect() {
  local query
  query=$(current_query)
  local track
  track=$(mpc current -f '%artist% - %title%')

  local cur_folder cur_genre cur_playlists
  cur_folder=$(beet_field "$query" folder)
  cur_genre=$(beet_field "$query" genre)
  cur_playlists=$(beet_field "$query" playlists)

  # Default folder to genre for uncollected tracks
  [[ -z "$cur_folder" ]] && cur_folder="$cur_genre"

  build_playlist_fields "$cur_playlists"

  local result
  result=$($YAD --form --title "Collect: $track" \
    --separator='|' \
    --field="Folder:CBE" "$(folder_combo "$cur_folder")" \
    --field="Playlists:LBL" "" \
    "${PL_YAD_ARGS[@]}" \
    2>/dev/null) || exit 0

  IFS='|' read -ra fields <<< "$result"
  local folder="${fields[0]}"
  # fields[1] is LBL
  local playlists
  playlists=$(parse_playlist_result "${fields[@]:2}")

  local mods=()
  [ -n "$folder" ] && mods+=("folder=$folder" "genre=$folder")
  [ "$playlists" != "$cur_playlists" ] && mods+=("playlists=$playlists")

  local item_id
  item_id=$(beet_id "$query")
  beet modify -y "$query" "${mods[@]}"
  local id_query="id:$item_id"
  beet move "$id_query"
  sync_comments "$id_query"
  cmd_splupdate_quiet
  local pos
  pos=$(mpc current -f '%position%')
  mpc del "$pos"
  mpc update --wait >/dev/null 2>&1 &
  notify-send "Music Collection" "Added: $track"
}

cmd_inbox() {
  mpc clear
  beet ls -f '$path' '^folder::.+' 2>/dev/null | while read -r path; do
    rel="${path#$HOME/Music/}"
    mpc add "$rel"
  done
  local count
  count=$(mpc playlist | wc -l)
  if [ "$count" -gt 0 ]; then
    mpc play
    notify-send "Music Inbox" "Loaded $count tracks"
  else
    notify-send "Music Inbox" "No inbox tracks"
  fi
}

cmd_import() {
  beet import "$@"
}

cmd_delete() {
  local query
  query=$(current_query)
  local title
  title=$(mpc current -f '%artist% - %title%')

  $YAD --question --title "Delete track" \
    --text "Delete \"$title\" from library and disk?" \
    2>/dev/null || exit 0

  local pos
  pos=$(mpc current -f '%position%')
  mpc del "$pos"
  beet remove -d -f "$query"
  beet splupdate >/dev/null 2>&1
  mpc update --wait >/dev/null 2>&1 &
  notify-send "Music" "Deleted: $title"
}

cmd_rename_playlist() {
  local names
  names=$(all_playlists)
  [[ -z "$names" ]] && { notify-send "Music" "No playlists found"; exit 1; }

  local old_name
  old_name=$(echo "$names" | wofi --dmenu --conf ~/.config/wofi/config --prompt "Rename which playlist?")
  [[ -z "$old_name" ]] && exit 0

  local new_name
  new_name=$($YAD --entry --title "Rename playlist" \
    --text "Rename \"$old_name\" to:" \
    --entry-text "$old_name" \
    2>/dev/null) || exit 0
  [[ -z "$new_name" || "$new_name" == "$old_name" ]] && exit 0

  beet ls -f '$id' "playlists:$old_name" 2>/dev/null | while read -r id; do
    local cur
    cur=$(beet ls -f '$playlists' "id:$id" 2>/dev/null | head -1)
    [[ "$cur" == '$playlists' ]] && continue
    # Replace old name with new name in comma-separated list
    local updated
    updated=$(echo "$cur" | tr ',' '\n' | sed 's/^ *//;s/ *$//' \
      | sed "s/^${old_name}$/${new_name}/" | paste -sd ',' -)
    beet modify -y "id:$id" "playlists=$updated"
    sync_comments "id:$id"
  done

  cmd_splupdate_quiet
  notify-send "Music" "Renamed playlist: $old_name â†’ $new_name"
}

cmd_splupdate_quiet() {
  # Let beets generate inbox.m3u
  beet splupdate >/dev/null 2>&1

  # Remove old playlist_*.m3u files
  rm -f ~/Music/playlists/playlist_*.m3u

  # Extract unique playlist names
  local names
  names=$(beet ls -f '$playlists' 'playlists::.+' 2>/dev/null \
    | tr ',' '\n' | sed 's/^ *//;s/ *$//' | grep -v '^\$' | grep -v '^$' | sort -fu)

  # Generate one .m3u per playlist
  while IFS= read -r name; do
    [[ -z "$name" ]] && continue
    local fname
    fname=$(echo "$name" | tr '[:upper:]' '[:lower:]' | tr ' ' '_')
    beet ls -f '$path' "playlists:$name" 2>/dev/null \
      | sed "s|$HOME/Music/||" > ~/Music/playlists/playlist_${fname}.m3u
  done <<< "$names"

  # Generate no_playlist.m3u â€” collected tracks without any playlist
  beet ls -f '$path' 'folder::.+' '^playlists::.+' 2>/dev/null \
    | sed "s|$HOME/Music/||" > ~/Music/playlists/no_playlist.m3u

  # Generate one .m3u per folder
  local folders
  folders=$(all_folders)
  while IFS= read -r folder; do
    [[ -z "$folder" ]] && continue
    local fname
    fname=$(echo "$folder" | tr '[:upper:]' '[:lower:]' | tr ' ' '_')
    beet ls -f '$path' "folder:$folder" 2>/dev/null \
      | sed "s|$HOME/Music/||" > ~/Music/playlists/${fname}.m3u
  done <<< "$folders"
}

cmd_splupdate() {
  cmd_splupdate_quiet
  notify-send "Music" "Playlists regenerated"
}

case "${1:-}" in
  play)      shift; cmd_play "$@" ;;
  search)    cmd_search ;;
  playlist)  cmd_playlist ;;
  random)    cmd_random ;;
  update)    cmd_update ;;
  collect)   cmd_collect ;;
  import)    shift; cmd_import "$@" ;;
  inbox)     cmd_inbox ;;
  delete)    cmd_delete ;;
  splupdate)        cmd_splupdate ;;
  rename_playlist)  cmd_rename_playlist ;;
  *)         echo "Usage: music {play|search|playlist|random|update|collect|import|inbox|delete|splupdate|rename_playlist}" >&2; exit 1 ;;
esac
