{
  "layer": "top",
  "reload_style_on_change": true ,
  "position": "bottom",
  "output": "!Invalid Vendor Codename - RTK 0x2775 0x20230814",
  "height": 32,
  "spacing": 8,
  "margin": "-6px 10px 0",
  "modules-left": [
    "custom/screenrecorder",
    "custom/btcusd",
    "custom/ethusdt",
    "custom/usdrub",
    "custom/eurrub",
    // "custom/dela"
    "custom/audio-inbox",
    "custom/audio-collection",
  ],
  "modules-center": [],
  "modules-right": [
    "custom/swap",
    "custom/zram",
    "custom/root-free-space",
    "custom/home-free-space",
    "cpu",
    "memory",
    // "custom/gpu-utilization",
    "temperature",
    "custom/power-usage",
    "pulseaudio",
    "network",
    "backlight",
    "keyboard-state",
    "battery",
    // "battery#bat2",
    "hyprland/language",
    "clock"
  ],

  "custom/btcusd": {
    "tooltip": false,
    "format": "п…ҡ {}",
    "exec": "grep 'BTCUSD:' ~/.cache/currencies | awk '{print $2}'",
    "interval": 60,
  },
  "custom/usdrub": {
    "tooltip": false,
    "format": "п…• {}",
    "exec": "grep 'USDRUB:' ~/.cache/currencies | awk '{print $2}'",
    "interval": 60,
  },
  "custom/eurrub": {
    "tooltip": false,
    "format": "п…“ {}",
    "exec": "grep 'EURRUB:' ~/.cache/currencies | awk '{print $2}'",
    "interval": 60,
  },
  "custom/ethusdt": {
    "tooltip": false,
    "format": "оҷ– {}",
    "exec": "grep 'ETHUSDT:' ~/.cache/currencies | awk '{print $2}'",
    "interval": 60,
  },
  "custom/dela": {
    "tooltip": false,
    "format": "оҡң  {}",
    "interval": 60,
    "exec": "~/.local/bin/dela list --today --format='$title' '/home/anton/Dev/@A/notes/*.md' | shuf -n 1",
    "on-click": "~/.local/bin/dela list --today --format='$title' '/home/anton/Dev/@A/notes/*.md' | shuf -n 1",
  },


  "pulseaudio": {
    "format": "{icon} {volume}%  {format_source}",
    "format-bluetooth": "{volume}% {icon} пҠ” {format_source}",
    "format-bluetooth-muted": "у°қҹ {icon} пҠ” {format_source}",
    "format-muted": "у°қҹ  {format_source}",
    "format-source": "п„°  {volume}%",
    "format-source-muted": "п„ұ",
    "format-icons": {
      "headphone": "пҖҘ ",
      "hands-free": "пҖҘ  ",
      "headset": "пҖҘ  ",
      "phone": "пӮ• ",
      "portable": "пӮ• ",
      "car": "пҶ№ ",
      "default": ["пҖҰ", "пҖ§", "пҖЁ "]
    },
    "on-click": "pavucontrol"
  },

  "hyprland/language": {
      "format": "{}",
      "format-en": "EN",
      "format-ru": "RU"
  },

  "clock": {
      "tooltip-format": "<tt>{calendar}</tt>",
      "format-alt": "{:%Y-%m-%d}"
  },

  "cpu": {
      "format": "CPU:{usage}%",
      "tooltip": false
  },

  "memory": {
      "format": "RAM:{}%"
  },

  "temperature": {
      // "thermal-zone": 2,
      // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
      "critical-threshold": 80,
      "format": "{icon} {temperatureC}В°C",
      "format-icons": ["пӢҠ", "пӢү", "пӢҮ"]
  },

  "backlight": {
      "format": "{icon} {percent}%",
      "format-icons": ["оҺҚ", "оҸ“", "оҸ‘", "оҸҸ", "оҸҺ", "оҸҚ", "оҸҠ", "оҸҲ", "оҺӣ"]
  },

  "battery": {
      "states": {
          "warning": 30,
          "critical": 15
      },
      "format": "{icon}  {capacity}%",
      "format-charging": "пҮҰ  {capacity}%",
      "format-plugged": "пҮҰ  {capacity}%",
      "format-alt": "{time} {icon}",
      "format-icons": ["пү„", "пүғ", "пүӮ", "пүҒ", "пүҖ"],
      "interval": 30
  },

  "network": {
      "max-length": 15,
      "format-wifi": "пҮ«  {essid}",
      "format-ethernet": "{ipaddr}/{cidr} пһ–",
      "tooltip-format": "{ifname} via {gwaddr} пһ–",
      "format-linked": "{ifname} (No IP) пһ–",
      "format-disconnected": "Disconnected вҡ ",
      "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },

  "custom/root-free-space": {
    "tooltip": false,
    "format": "/:{}GB",
    "interval": 300,
    // "exec": "sudo btrfs fi show / | awk '/size/{print $4-$6}' | cut -d. -f1"
    "exec": "df / --block-size=1G | awk '/nvme/{print $2-$3}'"
  },

  "custom/swap": {
    "tooltip": false,
    "format": "SW:{}",
    "interval": 300,
    "exec": "swapon --show | awk '/nvme/{print $4}'"
  },

  "custom/zram": {
    "tooltip": false,
    "format": "Z:{}",
    "interval": 300,
    "exec": "zramctl | awk '/zram/{print $4\" п…ё  \"$6}'"
  },

  "custom/home-free-space": {
    "tooltip": false,
    "format": "/home:{}GB",
    "interval": 300,
    "exec": "df /home --block-size=1G | awk '/home/{print $2-$3}'"
  },

  "custom/debug": {
    "exec": "cat ~/.emoticons | shuf -n1",
    "tooltip": false,
    "format": "{}",
    "interval": 1,
  },

  "custom/power-usage": {
    "tooltip": false,
    "format": "{}",
    "interval": 1,
    "exec": "$HOME/.config/waybar/bin/power-usage.sh"
  },

  "custom/gpu-utilization": {
    "tooltip": false,
    "format": "GPU:{}%",
    "interval": 30,
    "exec": "nvidia-smi --query-gpu utilization.gpu --format=csv,noheader | sed 's/ %//g'"
  },

  //"custom/screenrecorder": {
  //    "exec": "$HOME/.config/hypr/bin/waybar-wf-recorder.sh status",
  //    "interval": "once",
  //    "signal": 1,
  //    "return-type": "json",
  //    "tooltip": true,
  //    "format": "{}",
  //    "on-click": "$HOME/.config/hypr/bin/waybar-wf-recorder.sh toggle fullscreen",
  //    "on-click-right": "$HOME/.config/hypr/bin/waybar-wf-recorder.sh toggle region"
  //},

  "custom/screenrecorder": {
      "format" : "{}",
      "tooltip": true,
      "exec": "$HOME/.config/hypr/bin/waybar-wf-recorder.sh status",
      "return-type": "json",
      "interval": "once",
      "signal": 1,
      "on-click": "$HOME/.config/hypr/bin/waybar-wf-recorder.sh toggle region",
      "menu": "on-click-right",
      "menu-file": "~/.config/waybar/menus/screenshot.xml",
      "menu-actions": {
          "screenshot": "grim - | swappy -f -",
          "screenshot_area": "grim -g \"$(slurp)\" - | swappy -f -",
          "screencast": "~/.config/hypr/bin/waybar-wf-recorder.sh toggle fullscreen",
          "screencast_area": "~/.config/hypr/bin/waybar-wf-recorder.sh toggle region",
      },
  },

 "custom/audio-inbox": {
   "format": "INB:{}",
   "tooltip": false,
   "exec": "mpc playlist -f %time% \"inbox\" | awk -F: '{if(NF==3)s+=$1*3600+$2*60+$3;else if(NF==2)s+=$1*60+$2;else s+=$1}END{h=int(s/3600);m=int((s%3600)/60);printf \"%d:%02d\\n\",h,m}'",
   "interval": 60,
   "on-click": "thunar ~/Dropbox/inbox/"
 },
 
 "custom/audio-collection": {
   "format": "COL:{}",
   "tooltip": false, 
   "exec": "mpc playlist -f %time% \"collection\" | awk -F: '{if(NF==3)s+=$1*3600+$2*60+$3;else if(NF==2)s+=$1*60+$2;else s+=$1}END{h=int(s/3600);m=int((s%3600)/60);printf \"%d:%02d\\n\",h,m}'",
   "interval": 300,
   "on-click": "thunar ~/Dropbox/collection/"
 }

}
